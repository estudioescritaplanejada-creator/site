---
import { getCollection } from 'astro:content';
import { isPublished } from '../../lib/editorial';

const publishedArticles = await getCollection('articles', (article) => isPublished(article));
const activeCategories = new Set<string>(
  publishedArticles.map((article) => article.data.category),
);

const whatsappUrl =
  'https://wa.me/5511964502997?text=Ol%C3%A1%21%20Conheci%20o%20Est%C3%BAdio%20Escrita%20Planejada%20e%20gostaria%20de%20conversar%20sobre%20uma%20solu%C3%A7%C3%A3o%20digital%20para%20o%20meu%20neg%C3%B3cio.';

const editorialAreas = [
  {
    number: '01',
    slug: 'protecao-digital',
    tag: 'Não caia nessa',
    title: 'Golpes, acessos e riscos que podem parar seu trabalho',
    text: 'Alertas objetivos para reconhecer o problema, reduzir a exposição e agir antes que o prejuízo aumente.',
  },
  {
    number: '02',
    slug: 'decisoes-digitais',
    tag: 'Vale a pena pagar?',
    title: 'Decisões digitais sem desperdiçar dinheiro',
    text: 'Comparações e critérios para escolher ferramentas, planos, serviços e recursos com mais segurança.',
  },
  {
    number: '03',
    slug: 'rotina-digital',
    tag: 'Resolva agora',
    title: 'Soluções para a rotina de quem trabalha por conta própria',
    text: 'Passos claros para organizar mensagens, cobranças, arquivos, clientes, presença online e tarefas repetitivas.',
  },
  {
    number: '04',
    slug: 'ferramentas-e-ia',
    tag: 'Ferramentas aplicadas',
    title: 'IA e tecnologia sem linguagem técnica',
    text: 'Uso prático de ferramentas digitais para escrever, vender, organizar e produzir melhor sem depender de especialistas.',
  },
  {
    number: '05',
    slug: 'produtos-digitais',
    tag: 'Transforme seu conhecimento',
    title: 'Ideias que podem virar produtos digitais',
    text: 'Estrutura, conteúdo e apresentação para transformar experiência profissional em materiais úteis e comercializáveis.',
  },
];

const tools = [
  {
    status: 'Em preparação',
    title: 'Checklist de segurança do negócio',
    text: 'Uma verificação simples de senhas, acessos, dispositivos, backups e contas essenciais.',
  },
  {
    status: 'Em preparação',
    title: 'Inventário de acessos digitais',
    text: 'Modelo para registrar onde estão seus domínios, redes sociais, e-mails, sistemas e responsáveis.',
  },
  {
    status: 'Em preparação',
    title: 'Banco de mensagens profissionais',
    text: 'Respostas e modelos adaptáveis para orçamento, cobrança, confirmação, pós-venda e atendimento.',
  },
];
---

<a class="home-skip" href="#conteudo">Ir para o conteúdo principal</a>

<div class="utility-bar">
  <div class="home-container utility-bar__inner">
    <span>Vida digital prática</span>
    <span aria-hidden="true">•</span>
    <span>Guias, alertas e ferramentas para pequenos negócios</span>
  </div>
</div>

<header class="home-header">
  <div class="home-container home-header__inner">
    <a class="home-brand" href="/" aria-label="Estúdio Escrita Planejada — página inicial">
      <span class="home-brand__mark">EEP</span>
      <span class="home-brand__name">Estúdio Escrita Planejada</span>
    </a>

    <nav class="home-nav" aria-label="Navegação principal">
      <a href="/guias/">Guias</a>
      <a href="#ferramentas">Ferramentas</a>
      <a href="#servicos">Serviços</a>
      <a href="/site-profissional/">Site profissional</a>
    </nav>

    <a class="home-header__cta" href="#comece">Comece por aqui</a>

    <details class="home-menu">
      <summary aria-label="Abrir menu"><span></span><span></span><span></span></summary>
      <nav aria-label="Navegação móvel">
        <a href="/guias/">Guias</a>
        <a href="#ferramentas">Ferramentas</a>
        <a href="#servicos">Serviços</a>
        <a href="/site-profissional/">Site profissional</a>
        <a href="#comece">Comece por aqui</a>
      </nav>
    </details>
  </div>
</header>

<main id="conteudo">
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-container home-hero__grid">
      <div class="home-hero__copy">
        <p class="eyebrow">Para autônomos e pequenos negócios</p>
        <h1 id="home-title">Trabalhe melhor no digital. Sem complicação.</h1>
        <p class="home-hero__lead">
          Informação prática para organizar, proteger e desenvolver seu negócio —
          com orientações claras, ferramentas úteis e soluções que você consegue aplicar.
        </p>
        <div class="home-hero__actions">
          <a class="home-button home-button--primary" href="/guias/">Explorar os temas</a>
          <a class="home-button home-button--secondary" href="#servicos">Conhecer o Estúdio</a>
        </div>
        <ul class="home-hero__proof" aria-label="Características do conteúdo">
          <li>Sem jargão técnico</li>
          <li>Problema primeiro</li>
          <li>Ação concreta</li>
        </ul>
      </div>

      <aside class="signal-board" aria-label="Painel editorial do Estúdio">
        <div class="signal-board__top">
          <span>Painel prático</span>
          <span class="signal-board__live">Atualizado por temas</span>
        </div>
        <div class="signal-board__main">
          <p>O digital deve ajudar seu negócio — não criar mais confusão.</p>
          <strong>Veja o problema. Entenda o risco. Escolha o próximo passo.</strong>
        </div>
        <div class="signal-board__rows">
          <div><span>Alerta</span><strong>Evite perdas</strong><b>01</b></div>
          <div><span>Decisão</span><strong>Gaste melhor</strong><b>02</b></div>
          <div><span>Solução</span><strong>Resolva agora</strong><b>03</b></div>
          <div><span>Ferramenta</span><strong>Copie e adapte</strong><b>04</b></div>
        </div>
      </aside>
    </div>
  </section>

  <div class="editorial-strip" aria-hidden="true">
    <div>
      <span>Proteção digital</span><b>•</b>
      <span>Organização</span><b>•</b>
      <span>Ferramentas</span><b>•</b>
      <span>Presença online</span><b>•</b>
      <span>Produtos digitais</span><b>•</b>
    </div>
  </div>

  <section class="editorial-intro" id="guias" aria-labelledby="guias-title">
    <div class="home-container">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">O que você encontra aqui</p>
          <h2 id="guias-title">Conteúdo que começa no problema e termina numa ação.</h2>
        </div>
        <p>
          Nada de tecnologia abstrata. Cada território editorial parte de situações
          reais de quem atende clientes, vende, cobra, organiza arquivos e administra
          o próprio trabalho.
        </p>
      </div>

      <div class="editorial-grid">
        {editorialAreas.map((area, index) => (
          <article class:list={['editorial-card', index === 0 && 'editorial-card--featured']}>
            <div class="editorial-card__meta">
              <span>{area.number}</span>
              <span>{area.tag}</span>
            </div>
            <h3>{area.title}</h3>
            <p>{area.text}</p>
            <a
              class="editorial-card__action"
              href={activeCategories.has(area.slug) ? `/guias/tema/${area.slug}/` : '/guias/'}
            >
              {activeCategories.has(area.slug) ? 'Ver os guias →' : 'Em preparação →'}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="diagnostic" id="comece" aria-labelledby="diagnostic-title">
    <div class="home-container diagnostic__grid">
      <div class="diagnostic__intro">
        <p class="eyebrow eyebrow--light">Comece pelo que mais pesa hoje</p>
        <h2 id="diagnostic-title">Qual destes problemas está atrasando seu negócio?</h2>
        <p>
          A estrutura do Estúdio foi pensada para oferecer conteúdo gratuito,
          ferramentas e serviços dentro do mesmo caminho — sem empurrar uma solução
          que não combina com a necessidade.
        </p>
      </div>
      <div class="diagnostic__options">
        <a href="#ferramentas">
          <span>01</span>
          <strong>Tenho medo de perder acesso, dados ou dinheiro.</strong>
          <small>Proteção e verificação</small>
        </a>
        <a href="/guias/">
          <span>02</span>
          <strong>Perco tempo com tarefas digitais desorganizadas.</strong>
          <small>Rotina e produtividade</small>
        </a>
        <a href="/site-profissional/">
          <span>03</span>
          <strong>Meu trabalho não está bem apresentado na internet.</strong>
          <small>Presença profissional</small>
        </a>
        <a href="#servicos">
          <span>04</span>
          <strong>Tenho conhecimento, mas não sei transformá-lo em produto.</strong>
          <small>Infoproduto sob medida</small>
        </a>
      </div>
    </div>
  </section>

  <section class="tools" id="ferramentas" aria-labelledby="tools-title">
    <div class="home-container">
      <div class="section-heading section-heading--tools">
        <div>
          <p class="eyebrow">Ferramentas e materiais</p>
          <h2 id="tools-title">Recursos para usar — não apenas para ler.</h2>
        </div>
        <p>
          Checklists, modelos, diagnósticos, comparações e geradores serão incorporados
          ao acervo editorial conforme as primeiras coleções forem publicadas.
        </p>
      </div>

      <div class="tools-grid">
        {tools.map((tool, index) => (
          <article class="tool-card">
            <div class="tool-card__top">
              <span>{tool.status}</span>
              <b>0{index + 1}</b>
            </div>
            <h3>{tool.title}</h3>
            <p>{tool.text}</p>
            <span class="tool-card__label">Material gratuito</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="services" id="servicos" aria-labelledby="services-title">
    <div class="home-container">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">Soluções profissionais</p>
          <h2 id="services-title">Quando a orientação não basta, o Estúdio executa.</h2>
        </div>
        <p>
          Serviços organizados para pequenos negócios que precisam apresentar melhor
          seu trabalho, estruturar a presença digital ou transformar conhecimento em
          um material profissional.
        </p>
      </div>

      <div class="services-grid">
        <article class="service-card service-card--primary">
          <span class="service-card__number">01</span>
          <p class="service-card__tag">Serviço principal</p>
          <h3>Site profissional para mostrar seu trabalho e receber pedidos</h3>
          <p>
            Página completa, escrita e organizada pelo Estúdio, adaptada para celular,
            preparada para o Google e conectada ao seu WhatsApp.
          </p>
          <div class="service-card__actions">
            <a class="home-button home-button--light" href="/site-profissional/">Ver o serviço completo</a>
            <span>Projetos a partir de R$ 490*</span>
          </div>
        </article>

        <article class="service-card">
          <span class="service-card__number">02</span>
          <p class="service-card__tag">Estrutura digital</p>
          <h3>Presença digital organizada</h3>
          <p>
            Revisão e estruturação dos pontos essenciais do negócio: apresentação,
            canais, informações, mensagens e caminhos de contato.
          </p>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer">Conversar sobre o projeto →</a>
        </article>

        <article class="service-card">
          <span class="service-card__number">03</span>
          <p class="service-card__tag">Produto próprio</p>
          <h3>Infoproduto sob medida</h3>
          <p>
            Você traz a ideia e o conhecimento. O Estúdio transforma em um material
            organizado, escrito, visualmente profissional e pronto para apresentar ou vender.
          </p>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer">Apresentar uma ideia →</a>
        </article>
      </div>
    </div>
  </section>

  <section class="site-feature" aria-labelledby="site-feature-title">
    <div class="home-container site-feature__grid">
      <div class="site-feature__media">
        <img
          src="/assets/img/hero-mockup-principal.webp"
          alt="Exemplo de site profissional exibido em notebook"
          width="1672"
          height="941"
          loading="lazy"
          decoding="async"
        />
        <span>Projeto real do Estúdio</span>
      </div>
      <div class="site-feature__copy">
        <p class="eyebrow">Seu negócio merece um endereço próprio</p>
        <h2 id="site-feature-title">Pare de depender apenas do perfil nas redes sociais.</h2>
        <p>
          Reúna serviços, produtos, fotos, diferenciais e contato em uma página própria.
          O Estúdio cuida da organização, dos textos, do visual e da publicação.
        </p>
        <ul>
          <li>Atendimento online em todo o Brasil</li>
          <li>Uma página clara, rápida e responsiva</li>
          <li>Contato direcionado ao WhatsApp</li>
        </ul>
        <a class="home-button home-button--primary" href="/site-profissional/">Conhecer o site profissional</a>
      </div>
    </div>
  </section>

  <section class="final-call" aria-labelledby="final-call-title">
    <div class="home-container final-call__inner">
      <div>
        <p class="eyebrow eyebrow--light">Estúdio Escrita Planejada</p>
        <h2 id="final-call-title">Mais clareza para trabalhar, decidir e crescer no digital.</h2>
      </div>
      <div>
        <p>
          Use o conteúdo para resolver o que está ao seu alcance. Quando precisar de
          execução profissional, fale diretamente com o Estúdio.
        </p>
        <a class="home-button home-button--acid" href={whatsappUrl} target="_blank" rel="noopener noreferrer">Falar pelo WhatsApp</a>
      </div>
    </div>
  </section>
</main>

<footer class="home-footer">
  <div class="home-container home-footer__grid">
    <div>
      <a class="home-brand home-brand--footer" href="/">
        <span class="home-brand__mark">EEP</span>
        <span class="home-brand__name">Estúdio Escrita Planejada</span>
      </a>
      <p>Vida digital prática para quem trabalha por conta própria e administra pequenos negócios.</p>
    </div>
    <nav aria-label="Links institucionais">
      <a href="/guias/">Guias</a>
      <a href="#ferramentas">Ferramentas</a>
      <a href="#servicos">Serviços</a>
      <a href="/site-profissional/">Site profissional</a>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer">WhatsApp</a>
    </nav>
    <div class="home-footer__legal">
      <p>Atendimento online em todo o Brasil</p>
      <p><a href="mailto:estudioescritaplanejada@gmail.com">estudioescritaplanejada@gmail.com</a></p>
      <p>© 2026 Estúdio Escrita Planejada</p>
    </div>
  </div>
</footer>
