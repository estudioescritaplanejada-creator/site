---
import SeoHead from '../components/seo/SeoHead.astro';
import GoogleAnalytics from '../components/analytics/GoogleAnalytics.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string | null;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f4f0e8" />

    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href="/favicon-48.png"
    />
    <link
      rel="apple-touch-icon"
      href="/apple-touch-icon.png"
    />

    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      noindex={noindex}
    />

    <slot name="head" />
  </head>

  <body>
    <a class="skip-link" href="#conteudo">
      Pular para o conteúdo
    </a>

    <main id="conteudo">
      <slot />
    </main>
      <GoogleAnalytics />
  </body>
</html>
