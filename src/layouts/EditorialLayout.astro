---
import SeoHead from '../components/seo/SeoHead.astro';
import GoogleAnalytics from '../components/analytics/GoogleAnalytics.astro';
import '../styles/home.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  canonicalPath = '/',
  image = '/assets/img/og-estudio-escrita-planejada.jpg',
  imageAlt = 'Estúdio Escrita Planejada: vida digital prática para pequenos negócios',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f4f0e8" />
    <meta name="color-scheme" content="light" />

    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      author="Estúdio Escrita Planejada"
      image={image}
      imageAlt={imageAlt}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href="/favicon-48.png"
    />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Estúdio Escrita Planejada — Guias" href="/rss.xml" />

    <slot name="head" />
  </head>

  <body>
    <slot />
      <GoogleAnalytics />
  </body>
</html>
