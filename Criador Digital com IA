
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criador Digital com IA</title>
    <!-- Importação das Fontes do Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=League+Spartan:wght@400;600;700;800&display=swap" rel="stylesheet">
    <!-- Icones Lucide -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            /* Sistema de Cores Tech Warm - Fundo Claro */
            /* Core Colors (Sempre Fixas) */
            --azul-petroleo: #2A7F98;
            --roxo-tecnologico: #8E44AD;
            --amarelo-solar: #FDC316;
            /* Supporting Colors (Contextuais) */
            --verde-crescimento: #4F8246;
            --verde-menta: #5CB579;
            --coral: #FF9F43;
            --rosa-digital: #DE2F74;
            /* Neutral Colors - Fundo Claro */
            --branco-puro: #FFFFFF;
            --cinza-gelo: #F8FAFC;
            --cinza-suave: #E2E8F0;
            --cinza-medio: #CBD5E1;
            --cinza-escuro: #475569;
            --preto-suave: #1E293B;
            --preto-puro: #0F172A;
            /* Backgrounds para Fundo Claro */
            --bg-principal: var(--branco-puro);
            --bg-card: var(--cinza-gelo);
            --bg-secao: var(--branco-puro);
            --bg-destaque: var(--cinza-suave);
            /* Gradientes Sutis */
            --gradiente-suave: linear-gradient(135deg, #F8FAFC 0%, #E2E8F0 100%);
            --gradiente-destaque: linear-gradient(135deg, #FF9F43 0%, #DE2F74 100%);
            --gradiente-azul: linear-gradient(135deg, #2A7F98 0%, #1E5F73 100%);
            --gradiente-roxo: linear-gradient(135deg, #8E44AD 0%, #7B3F8A 100%);
            /* Texto - Alto Contraste para Fundo Branco */
            --texto-principal: var(--preto-puro);
            --texto-secundario: var(--preto-suave);
            --texto-terciario: var(--cinza-escuro);
            --texto-claro: var(--branco-puro);
            /* Sombras Sutilis */
            --sombra-leve: 0 1px 3px rgba(15, 23, 42, 0.1);
            --sombra-media: 0 4px 6px rgba(15, 23, 42, 0.1);
            --sombra-forte: 0 10px 25px rgba(15, 23, 42, 0.15);
            --sombra-cor: rgba(142, 68, 173, 0.2);
        }
        /* Reset e Estilos Gerais */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-principal);
            color: var(--texto-secundario);
            line-height: 1.6;
            overflow-x: hidden;
        }
        /* Container Principal */
        main {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 15px;
            position: relative;
        }
        /* Seções */
        section {
            padding: 80px 0;
            border-bottom: 1px solid var(--cinza-medio);
        }
        section:last-child {
            border-bottom: none;
        }
        /* Seção Hero com Fundo Destaque */
        .hero-section {
            padding: 150px 20px 100px;
            text-align: center;
            background: var(--gradiente-suave);
            position: relative;
        }
        .hero-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(142, 68, 173, 0.05) 1px, transparent 1px);
            background-size: 50px 50px;
            animation: float 20s ease-in-out infinite;
            pointer-events: none;
        }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        /* Seções com Fundo Alternado */
        .section-dark {
            background: var(--bg-card);
        }
        .section-destaque {
            background: var(--gradiente-suave);
        }
        /* Tipografia - Alto Contraste */
        h1, h2, h3 {
            font-family: 'League Spartan', sans-serif;
            font-weight: 800;
            color: var(--texto-principal);
            margin-bottom: 20px;
            line-height: 1.1;
            text-align: center;
        }
        h2 {
            font-size: 3rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        h2 span {
            background: var(--gradiente-destaque);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        h3 {
            font-size: 1.8rem;
            color: var(--texto-principal);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        p {
            margin-bottom: 20px;
            text-align: center;
            font-weight: 400;
            font-size: 1.1rem;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
            color: var(--texto-secundario);
        }
        .hero-title {
            font-size: 4.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            color: var(--texto-principal);
            margin-bottom: 30px;
            position: relative;
            z-index: 1;
        }
        .hero-title span {
            background: var(--gradiente-destaque);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .sub-headline {
            font-family: 'Inter', sans-serif;
            font-weight: 400;
            font-size: 1.6rem;
            color: var(--texto-secundario);
            max-width: 900px;
            margin: 0 auto 30px;
            opacity: 0.95;
            position: relative;
            z-index: 1;
        }
        /* Imagens */
        .mockup-image {
            display: block;
            max-width: 100%;
            height: auto;
            margin: 40px auto;
            border-radius: 12px;
            box-shadow: var(--sombra-forte);
            width: 500px;
            max-width: 100%;
        }
        /* Sistema de Grids */
        .grid-diferenciais {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin-top: 50px;
        }
        .grid-beneficios {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 40px;
        }
        .grid-pesquisa {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }
        .grid-dados {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }
        .grid-bonus {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }
        /* Cards - Fundo Claro */
        .card, .pesquisa-card, .dados-card {
            background: var(--branco-puro);
            border: 1px solid var(--cinza-medio);
            border-radius: 12px;
            padding: 30px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            box-shadow: var(--sombra-leve);
            color: var(--texto-principal);
        }
        .card::before, .pesquisa-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--gradiente-destaque);
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }
        .card:hover::before, .pesquisa-card:hover::before {
            transform: scaleX(1);
        }
        .card:hover, .pesquisa-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--sombra-forte);
            border-color: var(--azul-petroleo);
        }
        .card h3 {
            font-size: 1.4rem;
            color: var(--texto-principal);
            margin-bottom: 15px;
            font-weight: 700;
        }
        .card p {
            text-align: left;
            font-size: 0.95rem;
            margin-bottom: 0;
            color: var(--texto-secundario);
            font-weight: 400;
        }
        /* Card de Pesquisa */
        .pesquisa-card {
            padding: 25px 15px;
            cursor: pointer;
        }
        .pesquisa-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--sombra-media);
        }
        .pesquisa-numero {
            font-family: 'League Spartan', sans-serif;
            font-size: 2.8rem;
            font-weight: 800;
            color: var(--azul-petroleo);
            line-height: 1;
            margin-bottom: 8px;
        }
        .pesquisa-texto {
            font-size: 0.9rem;
            color: var(--texto-secundario);
            font-weight: 500;
            line-height: 1.3;
        }
        /* Card de Dados */
        .dados-card {
            border: 2px solid var(--cinza-medio);
            padding: 30px 20px;
        }
        .dados-card.destaque {
            border-color: var(--azul-petroleo);
            background: var(--branco-puro);
            position: relative;
            overflow: hidden;
            box-shadow: var(--sombra-cor);
        }
        .dados-card.destaque::before {
            content: 'Escolha Inteligente';
            position: absolute;
            top: 15px;
            right: 15px;
            background: var(--gradiente-destaque);
            color: var(--branco-puro);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        .dados-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--sombra-forte);
        }
        .dados-stat {
            font-family: 'League Spartan', sans-serif;
            font-size: 3rem;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 15px;
            color: var(--azul-petroleo);
        }
        .dados-descricao {
            font-size: 1.1rem;
            color: var(--texto-principal);
            font-weight: 600;
            line-height: 1.4;
            margin-bottom: 10px;
        }
        .dados-fonte {
            font-size: 0.9rem;
            color: var(--texto-terciario);
            font-style: italic;
            font-weight: 400;
        }
        /* Lista de Problemas */
        .lista-problemas {
            list-style: none;
            max-width: 800px;
            margin: 30px auto 0;
            text-align: left;
            padding: 0 10px;
        }
        .lista-problemas li {
            background: var(--branco-puro);
            border-left: 4px solid var(--azul-petroleo);
            padding: 15px;
            margin-bottom: 12px;
            border-radius: 0 8px 8px 0;
            font-size: 1rem;
            transition: all 0.3s ease;
            color: var(--texto-principal);
            box-shadow: var(--sombra-leve);
        }
        .lista-problemas li:hover {
            background: var(--cinza-gelo);
            transform: translateX(5px);
            box-shadow: var(--sombra-media);
        }
        /* Destaque de Método */
        .destaque-metodo {
            background: var(--branco-puro);
            border: 2px solid var(--roxo-tecnologico);
            border-radius: 12px;
            padding: 30px 20px;
            text-align: center;
            margin-top: 40px;
            box-shadow: var(--sombra-cor);
            color: var(--texto-principal);
        }
        .destaque-metodo p {
            font-size: 1.3rem;
            color: var(--texto-principal);
            font-weight: 700;
            margin: 0;
        }
        .destaque-metodo span {
            background: var(--gradiente-destaque);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        /* Cards Antes/Depois */
        .antes-depois {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-top: 40px;
        }
        .antes-depois .card:first-child {
            border-color: var(--coral);
        }
        .antes-depois .card:first-child h3 {
            color: var(--coral);
        }
        /* Preço */
        .secao-preco {
            background: var(--branco-puro);
            border: 3px solid var(--roxo-tecnologico);
            border-radius: 16px;
            padding: 40px 20px;
            margin-top: 50px;
            text-align: center;
            box-shadow: var(--sombra-cor);
            color: var(--texto-principal);
        }
        .valor-antigo {
            text-decoration: line-through;
            color: var(--texto-terciario);
            font-size: 1.5rem;
            margin-bottom: 10px;
        }
        .seu-investimento {
            font-size: 1.2rem;
            color: var(--texto-principal);
            margin-bottom: 5px;
        }
        .preco-final {
            font-family: 'League Spartan', sans-serif;
            font-size: 4rem;
            font-weight: 800;
            line-height: 1;
            margin: 20px 0;
            background: var(--gradiente-destaque);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .parcelamento {
            font-size: 1.2rem;
            color: var(--texto-principal);
            margin-bottom: 30px;
        }
        /* Tabela de Conteúdo */
        .tabela-conteudo {
            width: 100%;
            max-width: 1000px;
            margin: 30px auto;
            text-align: left;
            border: 1px solid var(--cinza-medio);
            border-radius: 12px;
            overflow: hidden;
            border-collapse: collapse;
            background: var(--branco-puro);
            box-shadow: var(--sombra-leve);
        }
        .tabela-conteudo tr {
            transition: background-color 0.3s;
        }
        .tabela-conteudo tr:nth-child(even) {
            background-color: var(--cinza-gelo);
        }
        .tabela-conteudo tr:hover {
            background-color: var(--cinza-suave);
        }
        .tabela-conteudo td {
            padding: 25px;
            border-bottom: 1px solid var(--cinza-medio);
        }
        .tabela-conteudo tr:last-child td {
            border-bottom: none;
        }
        .item-titulo {
            background: var(--gradiente-destaque);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
            font-family: 'League Spartan', sans-serif;
            font-size: 1.1rem;
            width: 30%;
            min-width: 150px;
        }
        .item-descricao {
            text-align: left;
            color: var(--texto-secundario);
            font-weight: 400;
        }
        /* Citação de Destaque */
        .citacao-destaque {
            background: var(--branco-puro);
            border-left: 4px solid var(--roxo-tecnologico);
            padding: 25px;
            margin: 30px auto;
            max-width: 800px;
            border-radius: 0 12px 12px 0;
            position: relative;
            color: var(--texto-principal);
            box-shadow: var(--sombra-leve);
        }
        .citacao-destaque::before {
            content: '"';
            position: absolute;
            top: -10px;
            left: 20px;
            font-size: 4rem;
            color: var(--roxo-tecnologico);
            opacity: 0.3;
            font-family: Georgia, serif;
        }
        .citacao-destaque p {
            font-size: 1.3rem;
            color: var(--texto-principal);
            text-align: left;
            margin: 0;
            font-style: italic;
            position: relative;
            z-index: 1;
        }
        /* Sistema de CTAs Tech Warm - Fundo Claro */
        .cta-group {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin-top: 50px;
            flex-wrap: wrap;
        }
        .cta-principal {
            display: inline-block;
            font-family: 'League Spartan', sans-serif;
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
            padding: 18px 40px;
            border-radius: 8px;
            transition: all 0.3s ease;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: var(--sombra-media);
            background: var(--gradiente-destaque);
            color: var(--branco-puro);
            border: none;
            text-shadow: 0 1px 2px rgba(0,0,0,0.2);
            width: 100%;
            max-width: 500px;
            position: relative;
            overflow: hidden;
        }
        .cta-principal::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }
        .cta-principal:hover::before {
            left: 100%;
        }
        .cta-principal:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: var(--sombra-forte);
            background: var(--roxo-tecnologico);
        }
        /* Benefícios CTA */
        .beneficios-cta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-top: 40px;
        }
        /* Footer */
        footer {
            background: var(--preto-puro);
            border-top: 1px solid var(--cinza-medio);
            color: var(--branco-puro);
            padding: 60px 15px 30px;
            text-align: center;
        }
        .copyright {
            margin-top: 20px;
            font-size: 0.9rem;
            color: var(--branco-puro);
        }
        /* Responsividade para Fundo Claro */
        @media (max-width: 1024px) {
            h2 { font-size: 2.5rem; }
            .hero-title { font-size: 3.5rem; }
            .sub-headline { font-size: 1.4rem; }
        }
        @media (max-width: 768px) {
            section { padding: 60px 0; }
            .hero-section { background: var(--branco-puro); }
            .section-dark { background: var(--cinza-gelo); }
            .card, .pesquisa-card, .dados-card {
                background: var(--branco-puro);
                box-shadow: var(--sombra-leve);
            }
            .mockup-image { box-shadow: var(--sombra-media); }
            h2 { font-size: 2rem; }
            .hero-title { font-size: 2.8rem; letter-spacing: -1px; }
            .sub-headline { font-size: 1.2rem; }
            .cta-group { flex-direction: column; gap: 15px; }
            .cta-principal { width: 100%; max-width: 350px; margin: 0 auto; }
            .antes-depois { grid-template-columns: 1fr; }
            .beneficios-cta { grid-template-columns: 1fr; }
            .tabela-conteudo td { display: block; width: 100%; }
            .item-titulo { width: 100%; text-align: center; padding-bottom: 0; }
            .item-descricao { text-align: center; padding-top: 5px; }
            .mockup-image { max-width: 100%; width: calc(100% - 40px); margin: 20px auto; }
        }
        @media (max-width: 500px) {
            .hero-title { font-size: 2rem; }
            .sub-headline { font-size: 1rem; }
            .card { padding: 20px; }
            .preco-final { font-size: 2.5rem; }
            .mockup-image { max-width: 100%; width: calc(100% - 20px); margin: 15px auto; }
        }
        @media (max-width: 320px) {
            main { padding: 0 10px; }
            .mockup-image { max-width: 100%; width: 100%; margin: 10px auto; }
        }
    </style>
